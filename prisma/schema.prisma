generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GameProvider {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  logoUrl   String?
  status    String   @default("active")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  games     Game[]
}

model Game {
  id           String   @id @default(cuid())
  providerCode String
  gameCode     String   @unique
  name         String
  category     String
  iconUrl      String?
  status       String   @default("active")
  isHot        Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  provider     GameProvider @relation(fields: [providerCode], references: [code], onDelete: Cascade)

  @@index([providerCode])
  @@index([category])
  @@index([status])
}

model ProviderWallet {
  id           String   @id @default(cuid())
  memberId     String
  providerCode String
  balance      Decimal  @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([memberId, providerCode])
  @@index([memberId])
  @@index([providerCode])
}

model ProviderTransaction {
  id                    String   @id @default(cuid())
  memberId              String
  providerCode          String
  gameCode              String?
  type                  String
  amount                Decimal
  beforeBalance         Decimal
  afterBalance          Decimal
  referenceId           String   @unique
  providerTransactionId String?
  status                String   @default("success")
  rawRequest            String?
  rawResponse           String?
  createdAt             DateTime @default(now())

  @@index([memberId])
  @@index([providerCode])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model ProviderSession {
  id           String   @id @default(cuid())
  memberId     String
  providerCode String
  gameCode     String
  sessionToken String   @unique
  launchUrl    String
  expiresAt    DateTime
  status       String   @default("active")
  createdAt    DateTime @default(now())

  @@index([memberId])
  @@index([providerCode])
  @@index([gameCode])
}

model ProviderConfig {
  id               String   @id @default(cuid())
  providerCode     String   @unique
  apiBaseUrl       String
  merchantIdEnc    String?
  agentIdEnc       String?
  apiKeyEnc        String?
  secretKeyEnc     String?
  webhookSecretEnc String?
  ipWhitelist      String?
  callbackUrl      String?
  walletMode       String   @default("transfer")
  currency         String   @default("THB")
  language         String   @default("th")
  status           String   @default("active")
  lastTestStatus   String?
  lastTestMessage  String?
  lastTestAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([providerCode])
  @@index([status])
}

model ProviderConfigAudit {
  id           String   @id @default(cuid())
  providerCode String
  action       String
  changedBy    String?
  maskedBefore String?
  maskedAfter  String?
  createdAt    DateTime @default(now())

  @@index([providerCode])
  @@index([createdAt])
}

model ProviderPlayer {
  id           String   @id @default(cuid())
  providerCode String
  memberId     String
  username     String
  displayName  String?
  currency     String   @default("THB")
  language     String   @default("th")
  status       String   @default("active")
  rawData      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([providerCode, memberId])
  @@unique([providerCode, username])
  @@index([memberId])
  @@index([providerCode])
  @@index([status])
}

model GameRound {
  id             String   @id @default(cuid())
  providerCode   String
  memberId       String
  gameCode       String
  roundId        String
  betAmount      Decimal  @default(0)
  winAmount      Decimal  @default(0)
  validBetAmount Decimal  @default(0)
  status         String   @default("open")
  rawData        String?
  startedAt      DateTime @default(now())
  settledAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([providerCode, roundId])
  @@index([memberId])
  @@index([providerCode])
  @@index([gameCode])
  @@index([status])
  @@index([createdAt])
}

model ProviderApiLog {
  id             String   @id @default(cuid())
  providerCode   String
  action         String
  direction      String   @default("inbound")
  requestMasked  String?
  responseMasked String?
  status         String   @default("success")
  durationMs     Int      @default(0)
  errorCode      String?
  createdAt      DateTime @default(now())

  @@index([providerCode])
  @@index([action])
  @@index([status])
  @@index([createdAt])
}
